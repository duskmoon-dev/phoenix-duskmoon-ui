{
  "name": "phoenix_duskmoon",
  "version": "9.1.4",
  "type": "module",
  "exports": {
    ".": "./priv/static/phoenix_duskmoon.js",
    "./hooks": "./assets/js/hooks/index.js",
    "./css": "./priv/static/phoenix_duskmoon.css",
    "./svg/mdi/*.svg": "./priv/mdi/svg/*.svg",
    "./svg/bsi/*.svg": "./priv/bsi/svg/*.svg"
  },
  "scripts": {
    "build": "mix tailwind duskmoon && mix bun duskmoon",
    "format": "bunx --bun @biomejs/biome format --write",
    "lint": "bunx --bun @biomejs/biome lint --write",
    "check": "bunx --bun @biomejs/biome check --write",
    "test": "bun test"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "assets/",
    "priv/static/",
    "priv/mdi/",
    "priv/bsi/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duskmoon-dev/phoenix-duskmoon-ui"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@duskmoon-dev/art-elements": "1.1.3",
    "@duskmoon-dev/core": "1.16.1",
    "@duskmoon-dev/css-art": "1.16.1",
    "@duskmoon-dev/elements": "1.1.3"
  },
  "devDependencies": {
    "@mdi/svg": "^7.4.47",
    "bootstrap-icons": "^1.13.1",
    "postcss": "8.5.9"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  }
}
