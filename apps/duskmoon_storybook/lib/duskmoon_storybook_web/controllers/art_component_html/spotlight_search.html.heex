<.dm_breadcrumb class="px-4">
  <:crumb to={~p"/art-component"}>Art Components</:crumb>
  <:crumb>Spotlight Search</:crumb>
</.dm_breadcrumb>

<.dm_card class="w-full h-full overflow-auto" body_class="p-4">
  <:title class="flex flex-row justify-center items-center gap-3">
    <span class="text-4xl text-primary">Spotlight Search</span>
  </:title>

  <.dm_markdown content={"""
  ## Notice

  The `dm_art_spotlight_search` component has been removed.
  Art components now use `@duskmoon-dev/art-elements` custom elements.
  """} />
</.dm_card>
